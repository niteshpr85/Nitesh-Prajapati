<div class="custom-banner">
  <div class="banner-content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.button_link }}" class="banner-btn">
      {{ section.settings.button_text }}
    </a>
  </div>
</div>

<style>
.custom-banner {
  height: 90vh;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 20px;
}

.banner-content {
  max-width: 600px;
}

.banner-content h1 {
  font-size: 48px;
  margin-bottom: 15px;
  font-weight: 700;
}

.banner-content p {
  font-size: 18px;
  margin-bottom: 25px;
  color: #666;
}

.banner-btn {
  display: inline-block;
  padding: 14px 32px;
  background: black;
  color: white;
  text-decoration: none;
  transition: all 0.3s ease;
}

.banner-btn:hover {
  transform: translateY(-3px);
}

/* MOBILE */
@media (max-width: 768px) {
  .banner-content h1 {
    font-size: 32px;
  }
}
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shop the best products"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}